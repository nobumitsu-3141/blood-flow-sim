#!/bin/bash
# 血流・脈波シミュレーター 起動スクリプト（macOS）
# このファイルをダブルクリックすると、ローカルサーバが立ち上がり
# 既定のブラウザでアプリ（index.html）が開きます。
# 終了するにはこのウィンドウを閉じてください。
#
# ※ サーバ無しでも、index.html をダブルクリックすれば開けます。
#   このスクリプトは他アプリと運用を揃えるためのものです。
cd "$(dirname "$0")" || exit 1
PORT=8242
echo "============================================"
echo " 血流・脈波シミュレーター を起動します"
echo " ブラウザで http://localhost:$PORT を開きます"
echo " 終了する時は、このウィンドウを閉じてください"
echo "============================================"
( sleep 1; open "http://localhost:$PORT/index.html" ) &
python3 -m http.server "$PORT"
